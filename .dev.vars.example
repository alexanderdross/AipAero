# Local secrets/vars for `pnpm preview` (Wrangler reads `.dev.vars`).
# Copy to `.dev.vars` (gitignored) and fill in. Mirrors the Worker secrets set
# in production with `wrangler secret put`.
CRON_SECRET=""
ADSENSE_ID=""
# Optional - OpenAIP core API key (embedded aerodrome-facts card).
OPENAIP_API_KEY=""
INDEXNOW_KEY=""
# Public read-only data API (/api/v1/*) Bearer token. Unset = API returns 503.
PUBLIC_API_KEY=""
# Contact form (/contact, /de/kontakt). Cloudflare Turnstile keys - the SITE key
# is public (rendered in the widget), the SECRET key gates server-side verify.
# Unset in dev = Cloudflare's always-pass test keys are used automatically.
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Netcup SMTP relay for delivering contact-form messages (worker-mailer over
# Cloudflare TCP sockets). Port 587 (STARTTLS) or 465 (implicit TLS); port 25 is
# blocked on Workers. SMTP_FROM must be a real mailbox on the sending domain so
# SPF/DMARC pass (defaults to SMTP_USER when unset).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
