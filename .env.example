# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# App
CRON_SECRET=""
ADSENSE_ID=""
# Optional: OpenAIP core API key for the embedded aerodrome-facts card
# (header `x-openaip-api-key`). Create one at https://www.openaip.net (profile ->
# API Key). When unset, facts fall back to the OurAirports data in D1.
OPENAIP_API_KEY=""
INDEXNOW_KEY=""
# Public read-only data API (/api/v1/*) Bearer token. Unset = API returns 503.
PUBLIC_API_KEY=""

# Contact form (/contact, /de/kontakt).
# Cloudflare Turnstile keys - SITE key is public (widget), SECRET key gates the
# server-side siteverify. Unset in dev = Cloudflare's always-pass test keys.
# Set the secret with `wrangler secret put TURNSTILE_SECRET_KEY`; the site key
# is a plain var (see wrangler.jsonc).
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Netcup SMTP relay for delivering contact-form messages (worker-mailer over
# Cloudflare TCP sockets, port 587 STARTTLS or 465 TLS - port 25 is blocked on
# Workers). SMTP_FROM must be a real mailbox on the sending domain (SPF/DMARC);
# defaults to SMTP_USER when unset. Set SMTP_PASS with `wrangler secret put`.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# The database is a Cloudflare D1 binding (`DB`) configured in wrangler.jsonc,
# not a connection string. For local `pnpm preview`, secrets/vars go in
# `.dev.vars` (see `.dev.vars.example`). Drizzle Kit push/studio against remote
# D1 additionally needs:
# CLOUDFLARE_ACCOUNT_ID=""
# CLOUDFLARE_DATABASE_ID=""
# CLOUDFLARE_D1_TOKEN=""
